{
  "name": "aerial",
  "version": "1.3.3",
  "videoJSONVersion": "1.15.0",
  "description": "Apple TV screen saver for Windows",
  "main": "app.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "build": "electron-builder build",
    "lint": "node --check app.js && node --check preload.js && node --check shared/video-utils.js && node --check web/config.js && node --check web/screensaver.js && node --check web/video-info.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phantasma2983/Aerial.git"
  },
  "author": "phantasma2983 (fork of OrangeJedi/Aerial)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/phantasma2983/Aerial/issues"
  },
  "homepage": "https://github.com/phantasma2983/Aerial#readme",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "auto-launch": "~5.0.6",
    "electron-store": "~11.0.2",
    "font-list-universal": "~1.0.0",
    "json-beautify": "~1.1.1",
    "suncalc": "~1.9.0"
  },
  "build": {
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "installerIcon": "icon.ico",
      "perMachine": false
    },
    "portable": {
      "artifactName": "aerial.exe",
      "useZip": true
    },
    "files": [
      "!assets/images/**"
    ],
    "icon": "icon.ico",
    "productName": "Aerial"
  }
}
